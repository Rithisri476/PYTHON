def prime(num):
   if (num>1):
      for i in range(2,int(num**0.5)+1):
         if (num%i==0):
            print("The given number is not a prime number")
            break
      else:
         print("The given number is prime number")
   else:
      print("The given is not a prime number")
num=int(input("Enter the number:"))
prime(num)

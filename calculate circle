class circle:
   def getval(self,r):
      self.r=r
      print ("Object created")
   def areaof(self):
      area=3.14*self.r*self.r
      print ("Area is ",area)
   def circum(self):
      circum=2*3.14*self.r
      print ("Circumference is ",circum)
obj=circle()
obj.getval(15)
obj.areaof()
obj.circum()

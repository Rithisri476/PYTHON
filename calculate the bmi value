class person:
   def __init__(self,name,age,weight,height):
      self.name=name
      self.age=age
      self.weight=weight
      self.height=height
   def get_bmi_result(self):
      he=(self.height*0.3048)
      bmi=(self.weight/(he**2))
      if(bmi<18.5):
         print("Underweight")
      elif(18.5<=bmi<=25):
         print("Healthy")
      else:
         print("Obeis")
obj= person('Rithi Sri',20,48,5.5)
obj.get_bmi_result()
